	<key>Language Features</key>
	<dict>
		<!-- '#' is included so tokens like #partial and #bounds_check
		     are recognised as single identifiers and can be matched
		     against the predefined-name list below. -->
		<key>Identifier and Keyword Character Class</key>
		<string>A-Za-z0-9_#</string>

		<!-- Regex string pattern: covers all three of Odin's literal
		     forms in one pass:
		       "..."   double-quoted, with \ escapes, no newline
		       `...`   raw / backtick, may span lines, no escapes
		       '...'   rune literal, with \ escapes -->
		<key>String Pattern</key>
		<string><![CDATA[
		(?x:
		  ( " (?: \\. | [^"\\\r\n] )* " )
		| ( ` [^`]* ` )
		| ( ' (?: \\. | [^'\\\r\n] )* ' )
		)
		]]></string>

		<!-- Regex comment pattern. Note: Odin permits nested block
		     comments; PCRE without recursion can't track nesting, so
		     this matches up to the first */ . Single-level block
		     comments work fine. -->
		<key>Comment Pattern</key>
		<string><![CDATA[
		(?x:
		  ( // .*? $ )
		| (?s: /\* .*? \*/ )
		)
		]]></string>

		<key>Open Statement Blocks</key>
		<string>{</string>
		<key>Close Statement Blocks</key>
		<string>}</string>
		<key>Open Parameter Lists</key>
		<string>(</string>
		<key>Close Parameter Lists</key>
		<string>)</string>
	</dict>

